# Cloudflare Pages edge headers — security + long-cache for hashed assets.
# Served from dist/_headers on the DEPLOYED site (Vite dev does NOT apply this).
#
# CSP notes:
#  - script-src 'self' only: the app ships a single external module bundle and
#    has no inline scripts. 'wasm-unsafe-eval' permits WebAssembly crypto without
#    allowing JS eval() (no 'unsafe-eval').
#  - style-src needs 'unsafe-inline' for React/RainbowKit inline style attributes.
#  - connect-src 'self' https: so ANY https RPC works — including a user's custom
#    per-chain RPC — plus the ticker APIs (api.llama.fi, api.coingecko.com).
#  - frame-ancestors 'self' for now; relax when the v1.5 embed mode ships.

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https:; frame-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
