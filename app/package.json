{
  "name": "openpendle",
  "private": true,
  "version": "0.0.0",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "check:alerts": "node --experimental-strip-types scripts/alerts-check.mjs",
    "check:limit-orders": "node --experimental-strip-types scripts/limit-order-check.mjs",
    "check:looping": "node --experimental-strip-types scripts/looping-check.mjs",
    "check:startup": "node --experimental-strip-types scripts/startup-recovery-check.mjs",
    "check:wallet-storage": "node --experimental-strip-types scripts/wagmi-storage-check.mjs",
    "check:catalog": "node --experimental-strip-types scripts/catalog-check.mjs",
    "check:factory-markets": "node --experimental-strip-types scripts/index-factory-markets.mjs --check",
    "check:factory-markets:complete": "node --experimental-strip-types scripts/index-factory-markets.mjs --check --require-complete",
    "check:m12": "node --experimental-strip-types scripts/m12-token-check.mjs",
    "check:positions": "node --experimental-strip-types scripts/positions-check.mjs",
    "index:factory-markets": "node --experimental-strip-types scripts/index-factory-markets.mjs",
    "preview": "vite preview",
    "sweep": "node --experimental-strip-types scripts/sweep.mjs"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "2.2.11",
    "@tanstack/react-query": "^5.101.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "viem": "^2.54.2",
    "wagmi": "2.19.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
