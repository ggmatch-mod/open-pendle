# WalletConnect Cloud project id (https://cloud.walletconnect.com).
# Optional: without it, injected wallets (MetaMask, Rabby, ...) still work;
# only the WalletConnect QR-code option needs a real id.
VITE_WALLETCONNECT_PROJECT_ID=

# Public build release flags only; never put wallet keys or RPC secrets in VITE_*.
# New entry additionally requires a fresh enabled app/public/looping-execution-policy.v1.json.
# Keep both flags and that runtime entry policy disabled until the final burner test passes.
VITE_LOOPING_EXECUTION_BETA_ENABLED=false
VITE_LOOPING_EXIT_BETA_ENABLED=false

# Local development only. Production builds ignore this even if set.
# Bypasses only the temporary beta amount caps; all execution safety checks remain.
VITE_LOOPING_UNCAPPED_TESTING_ENABLED=false
