# WalletConnect Cloud project id (https://cloud.walletconnect.com).
# Optional: without it, injected wallets (MetaMask, Rabby, ...) still work;
# only the WalletConnect QR-code option needs a real id.
VITE_WALLETCONNECT_PROJECT_ID=

# Public build release flags only; never put wallet keys or RPC secrets in VITE_*.
# Risk increases additionally require the fresh Market policy; Mint Mode also
# requires its separate app/public/looping-mint-execution-policy.v1.json gate.
# These remain off by default for self-hosted and local builds. OpenPendle's
# canonical Cloudflare main deployment enables Market entry/exit only; previews
# and Mint Mode stay off until separately released.
VITE_LOOPING_EXECUTION_BETA_ENABLED=false
VITE_LOOPING_MINT_BETA_ENABLED=false
VITE_LOOPING_EXIT_BETA_ENABLED=false

# Vite dev-server only. Set ALL=true to serve a one-hour Mint policy for every
# reviewed entry market on every supported chain, or use MARKET for one
# loopback market. They are mutually exclusive; production builds ignore both.
OPENPENDLE_LOCAL_MINT_POLICY_ALL=false
# Format: <chainId>:<Morpho market id>.
OPENPENDLE_LOCAL_MINT_POLICY_MARKET=
